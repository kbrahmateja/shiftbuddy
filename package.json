    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint-plugin-next-on-pages": "^1.13.16",
    "postcss": "^8.4.38",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
